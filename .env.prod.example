# ─── Renomeie este arquivo para .env.prod e preencha os valores ───────────────
# NUNCA commite o .env.prod no git!

# Domínio da sua aplicação (sem https://)
DOMAIN=app.clinikai.com.br

# PostgreSQL
POSTGRES_DB=clinikai
POSTGRES_USER=clinikai
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE_AQUI

# JWT (gere com: openssl rand -base64 64)
JWT_SECRET=TROQUE_POR_SECRET_FORTE_AQUI

# Google OAuth
GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu-client-secret

# Asaas
ASAAS_API_KEY=sua-api-key-asaas

# Z-API
ZAPI_INSTANCE_ID=seu-instance-id-zapi
ZAPI_TOKEN=seu-token-zapi
ZAPI_CLIENT_TOKEN=seu-client-token-zapi
ZAPI_SECURITY_TOKEN=seu-security-token-zapi

# Chave de criptografia (gere com: openssl rand -base64 32)
CRYPTO_MASTER_KEY_BASE64=TROQUE_POR_CHAVE_BASE64_AQUI

# N8N
N8N_WEBHOOK_URL=https://seu-n8n.com/webhook/clinikai

# AWS (para backup do banco)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=sua-access-key
AWS_SECRET_ACCESS_KEY=sua-secret-key
S3_BACKUP_BUCKET=clinikai-backups

